# Copy to .env and fill in. NEVER commit your real .env.

# --- Google Gemini (get a key at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Models ---
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536

# --- API auth (shared secret sent as X-API-Key header) ---
API_KEY=change-me-dev-key

# --- Retrieval tuning ---
SEMANTIC_TOP_K=20
BM25_TOP_K=20
RRF_K=60
RERANK_TOP_N=5
RERANK_MIN_SCORE=0.0

# --- Chunking ---
CHUNK_TOKENS=500
CHUNK_OVERLAP=80

# --- Generation ---
LLM_TEMPERATURE=0.0
MAX_CONTEXT_CHUNKS=5

# --- Paths ---
DATA_RAW_DIR=data/raw
DATA_INDEX_DIR=data/index

# --- UI gate (Streamlit shared password) ---
UI_PASSWORD=demo
